---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { SOCIALS } from "@/constants";

const posts = await getCollection("blog");

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class:list={["pt-12 pb-8", "border-b border-border"]}>
      <h1 class="my-4 inline-block text-4xl font-bold -tracking-wide sm:my-8 sm:text-5xl">
        Hi There!
      </h1>

      <div class="font-body text-base leading-relaxed">
      <p>
        I'm Prudhvi! I like working with low-level abstractions for the control
        they offer in composing solutions from the ground up using first
        principles.
      </p>
      <p class="mt-4">
        I hate writing bloated software, my coding philosophy is hugely
        influenced from
        <LinkButton
          class="underline decoration-dashed underline-offset-4 hover:text-accent"
          href="https://cscie2x.dce.harvard.edu/hw/ch01s06.html"
        >
          The Unix Philosophy
        </LinkButton> and
        <LinkButton
          class="underline decoration-dashed underline-offset-4 hover:text-accent"
          href="https://matklad.github.io/2022/10/06/hard-mode-rust.html"
        >
          Hard mode Rust
        </LinkButton>. These days my coding stack mostly involves Go, TypeScript and Python.
      </p>
      <p class="mt-4">
        I particularly like <strong>distributed systems, programming languages,
        machine learning, computer graphics</strong> and <strong>music.</strong>
      </p>
      </div>
      {
        SOCIALS.length > 0 && (
          <div class="mt-6 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">Find me:</div>
            <Socials />
          </div>
        )
      }
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-14 pb-8",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-14 pb-8">
          <h2 class="text-2xl font-semibold tracking-wide">Recent Posts</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        All Posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
