---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { SITE } from "@/config";

const projects = [
  {
    title: "Quill",
    description: "A minimal, dependency-free text editor in C with search and syntax highlighting.",
    tags: ["C", "Terminal"],
    link: "https://github.com/prudhvideep/quill",
  },
  {
    title: "Asteroids",
    description: "A retro arcade game in C compiled to WebAssembly, playable in the browser.",
    tags: ["C", "WebAssembly", "Raylib"],
    link: "https://github.com/prudhvideep/asteroids",
    demo: "https://prudhvideep.github.io/asteroids/asteroids.html",
  },
  {
    title: "Alloc",
    description: "Arena-style memory allocator with bump and free-list allocation strategies.",
    tags: ["C", "Systems"],
    link: "https://github.com/prudhvideep/alloc",
  },
  {
    title: "Relay",
    description: "Peer-to-peer file sharing over WebRTC with no server intermediating the transfer.",
    tags: ["TypeScript", "WebRTC", "Firebase"],
    link: "https://github.com/prudhvideep/Relay",
    demo: "https://relay-ubs.pages.dev/",
  },
];
---

<Layout title={`Projects | ${SITE.title}`}>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout pb-12">
    <h1 class="text-2xl font-semibold sm:text-3xl">Projects</h1>
    <p class="mt-3 mb-8 font-body italic">Learn to build, build to learn</p>

    <ul class="space-y-8">
      {projects.map((project, i) => (
        <li class:list={["pb-8", { "border-b border-border": i < projects.length - 1 }]}>
          <div class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between">
            <div class="flex-1">
              <h2 class="text-xl font-medium">
                <a href={project.link} target="_blank" rel="noopener noreferrer" class="hover:text-accent">
                  {project.title}
                </a>
              </h2>
              <p class="mt-2 font-body text-sm opacity-80">{project.description}</p>
              <div class="mt-3 flex flex-wrap gap-2">
                {project.tags.map(tag => (
                  <span class="rounded-full border border-accent/60 px-2.5 py-0.5 text-xs font-medium text-accent">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
            <div class="flex gap-3 text-sm sm:mt-1">
              <a href={project.link} target="_blank" rel="noopener noreferrer"
                 class="inline-flex items-center gap-1 hover:text-accent">
                Source
              </a>
              {project.demo && (
                <a href={project.demo} target="_blank" rel="noopener noreferrer"
                   class="inline-flex items-center gap-1 hover:text-accent">
                  Demo
                </a>
              )}
            </div>
          </div>
        </li>
      ))}
    </ul>
  </main>
  <Footer />
</Layout>
